{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "module": "CommonJS",
    "sourceMap": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@config/*": ["./config/*"]
    },
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "config/**/*", "tests/**/*", "playwright.config.ts"]
}

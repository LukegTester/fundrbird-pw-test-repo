{
  "name": "fundrbird-pw-test-repo",
  "version": "1.0.0",
  "description": "Playwright test automation framework for Rolnopol",
  "scripts": {
    "app:start": "docker compose up -d",
    "app:stop": "docker compose down",
    "app:wait": "wait-on http://localhost:3000",
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "npm run test -- --headed",
    "test:ui-mode": "npm run test -- --ui",
    "test:flaky": "node scripts/run-test-flaky.mjs",
    "tag:smoke": "playwright test --grep \"@smoke\"",
    "tag:api": "playwright test --grep \"@api\"",
    "tag:ui": "playwright test --grep \"@ui\"",
    "tag:mock": "playwright test --grep \"@mock\"",
    "tag:contract": "playwright test --grep \"@contract\"",
    "report:show": "playwright show-report",
    "quality:gate": "npm run quality:quick && npm test",
    "quality:quick": "npm run lint && npm run format-check && npm run typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format-check": "prettier . --check",
    "typecheck": "tsc --noEmit --pretty --strict",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "openapi-response-validator": "^12.1.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "wait-on": "^9.0.10"
  }
}
